---
title: Posts
layout: page
pageOrder: 1
---

<div class="list-group">
	<% for document in @getCollection('posts').toJSON(): %>
		<a class="list-group-item" href="<%= document.url %>">
			<small class="text-muted"><%= document.date.toDateString() %></small><br>
			<span class="h4 text-primary"><%= document.title %></span>
		</a>
	<% end %>
</div>
